PORT=4001
NODE_ENV="development"
HOST="localhost"
LOG_DIR="logs"
AUDIO_DIRECTORY="app/public"

# YOUTUBE API
YOUTUBE_API_URL="https://www.googleapis.com/youtube/v3"
YOUTUBE_API_KEY="your-youtube-api-key"

# PASSPORT AUTHENTICATION
PASSPORT_REDIRECT_URL=http://localhost:3000/home
PASSPORT_CALLBACK_URL=http://localhost:4001/api/auth/google/callback
APPLE_REDIRECT_URL=https://ydx-dev.youdescribe.org
APPLE_CALLBACK_URL=https://ydx-api.youdescribe.org/api/auth/apple/callback
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
CRYPTO_SECRET="your-crypto-secret"
CRYPTO_SEED="your-crypto-seed"

# DATABASE
CURRENT_DATABASE="mongodb"

# POSTGRES
POSTGRES_DB_NAME="ydxai"
POSTGRES_DB_USER="postgres"
POSTGRES_DB_PASSWORD="your-postgres-password"
POSTGRES_DB_PORT="5432"
POSTGRES_DB_HOST="localhost"

# MONGODB
# Option 1: Atlas connection string (takes precedence)
MONGO_DB_URI="mongodb+srv://user:password@cluster.mongodb.net/youdescribe?retryWrites=true&w=majority"
# Option 2: Individual host/port (used if MONGO_DB_URI is not set)
MONGO_DB_DATABASE="youdescribe"
MONGO_DB_HOST="127.0.0.1"
MONGO_DB_PORT="27017"
MONGO_DB_USER="youdescribe"
MONGO_DB_PASSWORD="your-mongo-password"

IMAGE_NAME="node_app"
IMAGE_TAG="dev"
OPENAI_API_KEY="your-openai-api-key"

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
AI_USER_ID=your-ai-user-object-id

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI PIPELINE SERVICES
AI_SERVICE_URL=http://localhost:8000
DOWNLOADER_SERVICE_URL=http://localhost:8001
S3_VIDEO_BUCKET=youdescribe-downloaded-youtube-videos
